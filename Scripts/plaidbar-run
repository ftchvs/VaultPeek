#!/bin/bash
# Deprecated compatibility shim: PlaidBar was renamed to VaultPeek.
# This wrapper forwards to vaultpeek-run and will be removed in a future release.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "plaidbar-run is deprecated; use vaultpeek-run instead." >&2
exec "$SCRIPT_DIR/vaultpeek-run" "$@"
